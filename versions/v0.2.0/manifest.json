      "Summary": "<p sourcefile=\"api/Wolfgang.Etl.Transformers.TakeTransformer-1.yml\" sourcestartlinenumber=\"1\">A transformer that yields at most a fixed number of items from the start of the input\nsequence.</p>\n"
    },
    {
      "type": "ManagedReference",
      "source_relative_path": "api/Wolfgang.Etl.Transformers.TakeWhileTransformer-1.yml",
      "output": {
        ".html": {
